{
  "name": "tapem-functions",
  "version": "1.0.0",
  "engines": {
    "node": "16"
  },
  "dependencies": {
    "firebase-admin": "^11.10.1",
    "firebase-functions": "^3.26.0"
  },
  "devDependencies": {
    "firebase-functions-test": "^0.3.3",
    "jest": "^29.7.0"
  },
  "scripts": {
    "test": "jest --runInBand --coverage"
  },
  "jest": {
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 0,
        "branches": 0,
        "functions": 0,
        "lines": 0
      }
    }
  }
}
