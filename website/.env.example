# Host-Konfiguration für lokale Entwicklung (optional)
NEXT_PUBLIC_MARKETING_HOST=localhost:3000
NEXT_PUBLIC_PORTAL_HOST=portal.localhost:3000
NEXT_PUBLIC_ADMIN_HOST=admin.localhost:3000

# --- Client (Web SDK) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_TAPEM_DEBUG=0

# Emulator (optional)
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false
NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
NEXT_PUBLIC_FIRESTORE_EMULATOR_HOST=localhost:8080

# --- Server (Admin SDK) ---
# Bevorzugt: Einzeiliges Base64 des Service-Account-JSON
FIREBASE_SERVICE_ACCOUNT=
# Alternativ:
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# Rollen (Allowlist & Claims)
ADMIN_ALLOWED_EMAILS=
# ADMIN_ALLOWLIST=

# Emulator (optional)
USE_FIREBASE_EMULATOR=false
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
FIRESTORE_EMULATOR_HOST=localhost:8080

# Dev-Preview-Rollenschalter (standardmäßig deaktiviert)
DEV_PREVIEW_ROLE_SWITCHES=false
