# ──────────────────────────────────────────────────────────────────────────────
# Host-Konfiguration (optional; nur falls in src/config/sites.ts genutzt)
# ──────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_MARKETING_HOST=localhost:3000
NEXT_PUBLIC_PORTAL_HOST=portal.localhost:3000
NEXT_PUBLIC_ADMIN_HOST=admin.localhost:3000

# ──────────────────────────────────────────────────────────────────────────────
# Firebase Web (Client; MINDESTENS diese 4 nötig)
# Diese Werte sind NICHT geheim, aber pro Projekt unterschiedlich.
# ──────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional empfohlen (werden automatisch unterstützt)
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Client-Debug (browserseitige Logs ausgeben: 0|1)
NEXT_PUBLIC_TAPEM_DEBUG=0

# Emulator (optional)
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false
NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
NEXT_PUBLIC_FIRESTORE_EMULATOR_HOST=localhost:8080

# ──────────────────────────────────────────────────────────────────────────────
# Firebase Admin (Server)
# Bevorzugt: Einzeiliges Base64 des Service-Account-JSON (ohne Anführungszeichen)
# Alternativ: Einzelwerte (bei PRIVATE_KEY auf echte Zeilenumbrüche achten)
# ──────────────────────────────────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT=
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Rollen (Allowlist ODER Custom Claims role=admin/owner)
ADMIN_ALLOWED_EMAILS=
# ADMIN_ALLOWLIST=

# Server-Emulator (optional)
USE_FIREBASE_EMULATOR=false
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
FIRESTORE_EMULATOR_HOST=localhost:8080

# Dev-Preview-Rollenschalter (falls UI das nutzt)
DEV_PREVIEW_ROLE_SWITCHES=false

# Server-Debug (serverseitige Logs: 0|1)
TAPEM_DEBUG=0
