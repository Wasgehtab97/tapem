rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────
    // Helper Functions
    // ─────────────────────────
    function isAuthed() {
      return request.auth != null;
    }

    function isAdminLikeRole(role) {
      return role == 'admin' || role == 'gymowner';
    }

    function isGymOwnerClaimForGym(gymId) {
      return isAuthed() &&
        request.auth.token.role == 'gymowner' &&
        request.auth.token.gymId == gymId;
    }

    // Membership: either custom claim gymId or membership doc under gym
    function inGym(gymId) {
      return isAuthed() && (
        request.auth.token.gymId == gymId ||
        exists(/databases/$(database)/documents/gyms/$(gymId)/users/$(request.auth.uid))
      );
    }

    // Admin if app-owner role or gym management role for this gym.
    function isAdmin(gymId) {
      return isGlobalAdmin() ||
        isGymAdmin(gymId) ||
        (
          inGym(gymId) &&
          (
            isGymOwnerClaimForGym(gymId) ||
            isAdminLikeRole(get(/databases/$(database)/documents/gyms/$(gymId)/users/$(request.auth.uid)).data.role)
          )
        );
    }

    // Coach if user has coachEnabled flag
    function isCoach(gymId) {
      return inGym(gymId) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.coachEnabled == true;
    }

    // Active coaching relation between current user (coach) and client
    function hasActiveCoaching(gymId, clientId) {
      let relId = gymId + '_' + request.auth.uid + '_' + clientId;
      let path = /databases/$(database)/documents/coachClientRelations/$(relId);
      return isAuthed() &&
             exists(path) &&
             get(path).data.status == 'active';
    }

    // Gym management claim (legacy name kept for compatibility).
    function isGymAdmin(gymId) {
      return isGymOwnerClaimForGym(gymId);
    }

    // App owner claim (legacy name kept for compatibility).
    function isGlobalAdmin() {
      return isAuthed() && request.auth.token.role == 'admin';
    }

    // Membership check
    function isMember(userId, gymId) {
      return exists(/databases/$(database)/documents/gyms/$(gymId)/users/$(userId));
    }

    function activeGymId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.activeGymId;
    }

    // Admin for the given gym and user (based on membership doc)
    function isGymAdminFor(userId, gymId) {
      return isAuthed() &&
             isMember(userId, gymId) &&
             isAdminLikeRole(get(/databases/$(database)/documents/gyms/$(gymId)/users/$(request.auth.uid)).data.role);
    }

    function isOwner(userId) {
      return isAuthed() && request.auth.uid == userId;
    }

    // Friend relation exists (symmetrische Kante)
    function isFriend(owner, viewer) {
      return exists(/databases/$(database)/documents/users/$(owner)/friends/$(viewer));
    }

    // Share at least one gym code (robust gegen fehlende Felder)
    function sharesGym(owner, viewer) {
      let ownerDoc = get(/databases/$(database)/documents/users/$(owner)).data;
      let viewerDoc = get(/databases/$(database)/documents/users/$(viewer)).data;
      let a = ownerDoc.gymCodes;
      let b = viewerDoc.gymCodes;
      return a != null && b != null && a.hasAny(b);
    }

    // Convenience: owner in gym or admin
    function ownerOrAdmin(gymId, userId) {
      return (request.auth.uid == userId && inGym(gymId)) || isAdmin(gymId);
    }

    // Write must be performed by the owner within the gym
    function requestOwnerInGym(gymId) {
      return inGym(gymId) && request.resource.data.userId == request.auth.uid;
    }

    // Read must refer to a doc owned by requester within gym, or admin
    function resourceOwnerOrAdmin(gymId) {
      return (inGym(gymId) && resource.data.userId == request.auth.uid) || isAdmin(gymId);
    }

    function canIncrementMemberNumberCounter() {
      let allowedKeys = resource.data.keys().concat(['memberNumberCounter']);
      return isAuthed() &&
        request.resource.data.keys().hasOnly(allowedKeys) &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['memberNumberCounter']) &&
        request.resource.data.memberNumberCounter is int &&
        request.resource.data.memberNumberCounter <= 9999 &&
        (
          !('memberNumberCounter' in resource.data) && request.resource.data.memberNumberCounter >= 0 ||
          (
            resource.data.memberNumberCounter is int &&
            request.resource.data.memberNumberCounter == resource.data.memberNumberCounter + 1
          )
        );
    }

    function canGlobalAdminAdjustGymCodes(uid) {
      let changed = request.resource.data.diff(resource.data).changedKeys();
      let prevCodes = resource.data.gymCodes;
      let nextCodes = request.resource.data.gymCodes;
      return isAuthed() &&
        isGlobalAdmin() &&
        prevCodes is list &&
        nextCodes is list &&
        changed.hasOnly(['gymCodes', 'activeGymId', 'updatedAt']) &&
        nextCodes.size() <= 50 &&
        nextCodes.hasOnly(prevCodes) &&
        (
          !('activeGymId' in request.resource.data) ||
          (
            request.resource.data.activeGymId is string &&
            nextCodes.hasAny([request.resource.data.activeGymId])
          )
        ) &&
        (
          !('updatedAt' in request.resource.data) ||
          request.resource.data.updatedAt is timestamp
        );
    }

    function canGymAdminDetachUserFromGym(uid, gymId) {
      let changed = request.resource.data.diff(resource.data).changedKeys();
      let prevCodes = resource.data.gymCodes;
      let nextCodes = request.resource.data.gymCodes;
      return isAuthed() &&
        gymId is string &&
        isGymAdminFor(uid, gymId) &&
        prevCodes is list &&
        nextCodes is list &&
        prevCodes.hasAny([gymId]) &&
        !nextCodes.hasAny([gymId]) &&
        nextCodes.size() == prevCodes.size() - 1 &&
        nextCodes.size() <= 50 &&
        nextCodes.hasOnly(prevCodes) &&
        changed.hasOnly(['gymCodes', 'activeGymId', 'updatedAt']) &&
        (
          !('activeGymId' in request.resource.data) ||
          (
            request.resource.data.activeGymId is string &&
            nextCodes.hasAny([request.resource.data.activeGymId])
          )
        ) &&
        (
          !('updatedAt' in request.resource.data) ||
          request.resource.data.updatedAt is timestamp
        );
    }

    // Owner or friend based on a given field
    function isOwnerOrFriend(field) {
      return (field in resource.data) &&
        (resource.data[field] == request.auth.uid ||
         isFriend(resource.data[field], request.auth.uid));
    }

    function chatExists(conversationId) {
      return exists(/databases/$(database)/documents/friendConversations/$(conversationId));
    }

    function chatMembers(conversationId) {
      return get(/databases/$(database)/documents/friendConversations/$(conversationId)).data.members;
    }

    function isChatParticipant(conversationId) {
      return isAuthed() && chatExists(conversationId) &&
        chatMembers(conversationId).hasAny([request.auth.uid]);
    }

    function isSingleDevice(gymId, machineId) {
      let deviceDoc = get(/databases/$(database)/documents/gyms/$(gymId)/devices/$(machineId)).data;
      return deviceDoc != null && deviceDoc.isMulti == false;
    }

    function fieldEmpty(field) {
      return !(field in resource.data) || resource.data[field] == null || resource.data[field] == '';
    }

    // Public exercise if none of the owner fields are set (READ context uses resource)
    function isPublicExercise() {
      return fieldEmpty('userId') && fieldEmpty('ownerId') && fieldEmpty('createdBy');
    }

    function isFeedEventAllowedKeys(data) {
      return data.keys().hasOnly([
        'type',
        'createdAt',
        'dayKey'
      ]);
    }

    function isFeedEventId(eventId, dayKey, userId) {
      return eventId == dayKey + '_' + userId;
    }

    function optionalStringField(data, field) {
      return !(field in data) || data[field] is string;
    }

    function optionalIntField(data, field) {
      return !(field in data) || data[field] is int;
    }

    function optionalNumberField(data, field) {
      return !(field in data) || data[field] is number;
    }

    function isNutritionDateKey(key) {
      return key.matches('^\\d{8}$');
    }

    function isYearKey(key) {
      return key.matches('^\\d{4}$');
    }

    function isBarcodeKey(key) {
      return key.matches('^\\d{8}$') ||
        key.matches('^\\d{12}$') ||
        key.matches('^\\d{13}$') ||
        key.matches('^\\d{14}$');
    }

    function isNutritionMacros(data) {
      return data is map &&
        data.keys().hasOnly(['protein', 'carbs', 'fat']) &&
        data.protein is int &&
        data.carbs is int &&
        data.fat is int;
    }

    function isNutritionTotals(data) {
      return data is map &&
        data.keys().hasOnly(['kcal', 'protein', 'carbs', 'fat']) &&
        data.kcal is int &&
        data.protein is int &&
        data.carbs is int &&
        data.fat is int;
    }

    // ─────────────────────────
    // Activity stream (server only)
    // ─────────────────────────
    match /gyms/{gymId}/activity/{eventId} {
      allow read: if false;
      allow write: if false;
    }

    // ─────────────────────────
    // Global logs read (owner-only)
    // ─────────────────────────
    match /{path=**}/logs/{logId} {
      allow read: if isAuthed() &&
        (resource.data.userId == request.auth.uid ||
         isFriend(resource.data.userId, request.auth.uid));
      allow delete: if isAuthed() &&
        resource.data.userId == request.auth.uid;
    }

    // ─────────────────────────
    // Friend Requests (top-level)
    // ─────────────────────────
    match /friendRequests/{reqId} {
      allow read: if isAuthed() &&
        (request.auth.uid == resource.data.fromUserId ||
         request.auth.uid == resource.data.toUserId);

      allow create: if request.auth.uid == request.resource.data.fromUserId &&
        request.resource.data.fromUserId != request.resource.data.toUserId &&
        request.resource.data.status == 'pending' &&
        reqId == request.resource.data.fromUserId + '_' + request.resource.data.toUserId &&
        request.resource.data.keys().hasOnly(['fromUserId','toUserId','status','createdAt','updatedAt','message']) &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.updatedAt is timestamp &&
        (!('message' in request.resource.data) ||
          (request.resource.data.message is string &&
           request.resource.data.message.size() <= 280));

      allow update: if request.resource.data.keys().hasOnly(['fromUserId','toUserId','status','createdAt','updatedAt','message']) &&
        request.resource.data.fromUserId == resource.data.fromUserId &&
        request.resource.data.toUserId == resource.data.toUserId &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.updatedAt is timestamp && (
          (request.auth.uid == resource.data.fromUserId && resource.data.status == 'pending' &&
            request.resource.data.status == 'canceled') ||
          (request.auth.uid == resource.data.toUserId && resource.data.status == 'pending' &&
            (request.resource.data.status == 'accepted' || request.resource.data.status == 'declined'))
        );

      allow delete: if false;
    }

    // ─────────────────────────
    // Friend chat conversations
    // ─────────────────────────
    match /friendConversations/{conversationId} {
      // Can read if you're a member of the conversation
      allow read: if isAuthed() &&
        resource.data.members.hasAny([request.auth.uid]);

      // Anyone can create if they're one of the members
      allow create: if isAuthed() &&
        request.resource.data.keys().hasOnly([
          'members',
          'createdAt',
          'updatedAt',
          'lastMessage',
          'lastReadAt'
        ]) &&
        request.resource.data.members is list &&
        request.resource.data.members.size() == 2 &&
        request.resource.data.members.hasAny([request.auth.uid]) &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.updatedAt is timestamp;

      // Can update if you're a participant and not changing members
      // Also allows updating own lastReadAt timestamp
      allow update: if isAuthed() &&
        resource.data.members.hasAny([request.auth.uid]) &&
        request.resource.data.members == resource.data.members;

      allow delete: if false;

      match /messages/{messageId} {
        // Can read messages if you're a member of the conversation
        allow read: if isAuthed() && isChatParticipant(conversationId);

        // Can create message if you're the sender and a conversation member
        allow create: if isAuthed() &&
          request.resource.data.senderId == request.auth.uid &&
          isChatParticipant(conversationId) &&
          request.resource.data.keys().hasOnly(['senderId', 'type', 'createdAt', 'text', 'highlightData', 'isEncrypted', 'nonce', 'stickerId']) &&
          request.resource.data.type is string &&
          request.resource.data.createdAt is timestamp &&
          (!('isEncrypted' in request.resource.data) || request.resource.data.isEncrypted is bool) &&
          (!('nonce' in request.resource.data) || request.resource.data.nonce is string) &&
          (!('stickerId' in request.resource.data) || request.resource.data.stickerId is string);


        allow update, delete: if false;
      }
    }

    // ─────────────────────────
    // Conversation encryption keys
    // ─────────────────────────
    match /conversationKeys/{conversationId}/participants/{userId} {
      // Can read own encrypted key
      allow read: if isAuthed() && userId == request.auth.uid;
      
      // Can create if you're a participant in the conversation
      allow create: if isAuthed() &&
        isChatParticipant(conversationId) &&
        request.resource.data.keys().hasOnly(['conversationId', 'userId', 'encryptedKey', 'createdAt', 'encryptedBy']) &&
        request.resource.data.conversationId is string &&
        request.resource.data.userId is string &&
        request.resource.data.encryptedKey is string &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.encryptedBy is string &&
        request.resource.data.encryptedBy == request.auth.uid;
      allow update: if isAuthed() &&
        isChatParticipant(conversationId) &&
        request.resource.data.keys().hasOnly(['conversationId', 'userId', 'encryptedKey', 'createdAt', 'encryptedBy']) &&
        request.resource.data.conversationId is string &&
        request.resource.data.userId is string &&
        request.resource.data.encryptedKey is string &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.encryptedBy is string &&
        request.resource.data.encryptedBy == request.auth.uid;
      
      allow delete: if false;
    }

    // ─────────────────────────
    // Stickers collection
    // ─────────────────────────
    match /stickers/{stickerId} {
      allow read: if isAuthed();
      allow write: if isGlobalAdmin();
    }

    // ─────────────────────────
    // Manufacturers collection (global list)
    // ─────────────────────────
    match /manufacturers/{manufacturerId} {
      allow read: if isAuthed();
      // Global catalog writes are server/app-owner only.
      allow write: if isGlobalAdmin();
    }

    // ─────────────────────────
    // Avatar catalog global
    // ─────────────────────────
    match /catalogAvatarsGlobal/{avatarId} {
      allow read: if isAuthed();
      allow write: if isGlobalAdmin();
    }

    // ─────────────────────────
    // Public profiles (legacy)
    // ─────────────────────────
    match /public_profiles/{uid} {
      allow read: if isAuthed();
      allow create: if isOwner(uid) &&
        request.resource.data.keys().hasOnly(['avatarKey', 'usernameLower', 'createdAt']) &&
        request.resource.data.avatarKey is string &&
        request.resource.data.createdAt is timestamp &&
        (!('usernameLower' in request.resource.data) || request.resource.data.usernameLower is string);
      allow update: if isOwner(uid) &&
        request.resource.data.keys().hasOnly(['avatarKey', 'usernameLower']) &&
        request.resource.data.avatarKey is string &&
        (!('usernameLower' in request.resource.data) || request.resource.data.usernameLower is string);
      allow update: if isGymAdminFor(uid, request.auth.token.gymId) &&
        request.resource.data.keys().hasOnly(['usernameLower']) &&
        request.resource.data.usernameLower is string;
      allow delete: if false;
    }

    // Public profiles (canonical)
    match /publicProfiles/{uid} {
      allow read: if isAuthed();
      allow create: if isOwner(uid) &&
        request.resource.data.keys().hasOnly(['avatarKey', 'usernameLower', 'createdAt']) &&
        request.resource.data.avatarKey is string &&
        request.resource.data.createdAt is timestamp &&
        (!('usernameLower' in request.resource.data) || request.resource.data.usernameLower is string);
      allow update: if isOwner(uid) &&
        request.resource.data.keys().hasOnly(['avatarKey', 'usernameLower']) &&
        request.resource.data.avatarKey is string &&
        (!('usernameLower' in request.resource.data) || request.resource.data.usernameLower is string);
      allow update: if isGymAdminFor(uid, request.auth.token.gymId) &&
        request.resource.data.keys().hasOnly(['usernameLower']) &&
        request.resource.data.usernameLower is string;
      allow delete: if false;
    }

    // ─────────────────────────
    // Usernames mapping
    // ─────────────────────────
      match /usernames/{name} {
        allow read: if isAuthed();
        allow create: if isOwner(request.resource.data.uid) &&
          !exists(/databases/$(database)/documents/usernames/$(name)) &&
          request.resource.data.keys().hasOnly(['uid','createdAt']) &&
          request.resource.data.createdAt is timestamp;
        allow update: if isOwner(resource.data.uid) &&
          request.resource.data.keys().hasOnly(['uid','createdAt']) &&
          (!('uid' in request.resource.data) ||
            request.resource.data.uid == resource.data.uid) &&
          (!('createdAt' in request.resource.data) ||
            request.resource.data.createdAt is timestamp);
        allow delete: if isOwner(resource.data.uid);
      }

    // ─────────────────────────
    // Users (top-level)
    // ─────────────────────────
    match /users/{uid} {
      // Keep profile readable for authed users (e.g., username checks)
      allow create: if isOwner(uid);
      allow read: if isAuthed();
      allow update: if isOwner(uid) &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'username',
          'usernameLower',
          'showInLeaderboard',
          'publicProfile',
          'publicKey',
          'avatarUrl',
          'avatarKey',
          'avatarUpdatedAt',
          'equippedAvatarRef',
          'activeGymId',
          'gymCodes'
        ]) &&
        (
          !('gymCodes' in request.resource.data) ||
          (
            request.resource.data.gymCodes is list &&
            request.resource.data.gymCodes.size() <= 50
          )
        );
      allow update: if isGymAdminFor(uid, request.auth.token.gymId) &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['avatarKey']) &&
        request.resource.data.avatarKey is string;
      allow update: if isGymAdminFor(uid, request.auth.token.gymId) &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['coachEnabled']) &&
        request.resource.data.coachEnabled is bool;
      allow update: if canGlobalAdminAdjustGymCodes(uid);
      allow update: if canGymAdminDetachUserFromGym(uid, request.auth.token.gymId);

      // Friends list (symmetrische Kante)
      match /friends/{fid} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid) && uid != fid &&
          request.resource.data.keys().hasOnly(['createdAt']) &&
          request.resource.data.createdAt is timestamp;
        allow delete: if isOwner(uid);
      }

      match /avatarsOwned/{avatarId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      match /avatarInventory/{docId} {
        allow read: if isOwner(uid) || isGlobalAdmin() || isGymAdminFor(uid,
          resource.data.gymId != null ? resource.data.gymId : request.auth.token.gymId);

        allow create: if (isOwner(uid) || isGlobalAdmin() || isGymAdminFor(uid,
              request.resource.data.gymId != null ? request.resource.data.gymId : request.auth.token.gymId)) &&
          request.resource.data.keys().hasOnly(['key', 'source', 'gymId', 'createdAt', 'updatedAt']) &&
          request.resource.data.source in ['user/self', 'admin/manual'] &&
          request.resource.data.key.matches('^[A-Za-z0-9_-]+/[A-Za-z0-9_-]+$') &&
          ((request.resource.data.key.matches('^global/[A-Za-z0-9_-]+$') && !('gymId' in request.resource.data)) ||
           (request.resource.data.gymId != null &&
            request.resource.data.key.matches('^' + request.resource.data.gymId + '/[A-Za-z0-9_-]+$'))) &&
          (!('createdAt' in request.resource.data) ||
            (request.resource.data.createdAt is timestamp &&
             request.resource.data.createdAt == request.time));

        allow delete: if isOwner(uid) || isGlobalAdmin() || isGymAdminFor(uid,
          resource.data.gymId != null ? resource.data.gymId : request.auth.token.gymId);

        allow update: if false;
      }

      // Privacy-aware public calendar (server writes)
      match /publicCalendar/{month} {
        allow read: if isAuthed() && (
          isOwner(uid) ||
          get(/databases/$(database)/documents/users/$(uid)).data.calendarVisibility == 'public' ||
          (
            get(/databases/$(database)/documents/users/$(uid)).data.calendarVisibility == 'friends' &&
            isFriend(uid, request.auth.uid)
          ) ||
          (
            get(/databases/$(database)/documents/users/$(uid)).data.calendarVisibility == 'same_gym' &&
            sharesGym(uid, request.auth.uid)
          )
        );
        allow write: if false; // only via Cloud Functions
      }

      // Friend meta & push tokens are owner-managed
      match /friendMeta/{doc} {
        allow read, write: if isOwner(uid);
      }

      match /friendChats/{friendUid} {
        allow read: if isOwner(uid);
        allow create, update: if isAuthed() &&
          (request.auth.uid == uid || request.auth.uid == friendUid) &&
          request.resource.data.keys().hasOnly([
            'conversationId',
            'hasUnread',
            'lastMessage',
            'lastMessageAt',
            'lastMessageSenderId',
            'updatedAt',
            'lastReadAt'
          ]) &&
          (!('conversationId' in request.resource.data) ||
            request.resource.data.conversationId is string) &&
          (!('hasUnread' in request.resource.data) ||
            request.resource.data.hasUnread is bool) &&
          (!('lastMessage' in request.resource.data) ||
            (request.resource.data.lastMessage is string &&
             request.resource.data.lastMessage.size() > 0)) &&
          (!('lastMessageAt' in request.resource.data) ||
            (request.resource.data.lastMessageAt is timestamp ||
             request.resource.data.lastMessageAt == request.time)) &&
          (!('lastMessageSenderId' in request.resource.data) ||
            request.resource.data.lastMessageSenderId is string) &&
          (!('updatedAt' in request.resource.data) ||
            (request.resource.data.updatedAt is timestamp ||
             request.resource.data.updatedAt == request.time)) &&
          (!('lastReadAt' in request.resource.data) ||
            (request.auth.uid == uid &&
              (request.resource.data.lastReadAt is timestamp ||
               request.resource.data.lastReadAt == request.time)));
        allow delete: if isOwner(uid);
      }

      match /pushTokens/{token} {
        allow read, write: if isOwner(uid);
      }

      match /settings/{doc} {
        allow read, write: if isOwner(uid);
      }

      match /creatine_intakes/{date} {
        allow read, write: if isOwner(uid);
      }

      match /nutrition_goal_templates/{templateId} {
        allow read, write: if isOwner(uid);
      }

      match /nutrition_goals/{dateKey} {
        allow read: if isOwner(uid) && isNutritionDateKey(dateKey);
        allow create, update: if isOwner(uid) &&
          isNutritionDateKey(dateKey) &&
          request.resource.data.keys().hasOnly(['kcal', 'macros', 'source', 'updatedAt']) &&
          request.resource.data.kcal is int &&
          isNutritionMacros(request.resource.data.macros) &&
          (!('source' in request.resource.data) || request.resource.data.source is string) &&
          (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is timestamp);
        allow delete: if isOwner(uid) && isNutritionDateKey(dateKey);
      }

      match /nutrition_logs/{dateKey} {
        allow read: if isOwner(uid) && isNutritionDateKey(dateKey);
        allow create, update: if isOwner(uid) &&
          isNutritionDateKey(dateKey) &&
          request.resource.data.keys().hasOnly(['date', 'total', 'entries', 'status', 'updatedAt']) &&
          (!('date' in request.resource.data) || request.resource.data.date is string) &&
          isNutritionTotals(request.resource.data.total) &&
          (!('entries' in request.resource.data) ||
            (request.resource.data.entries is list &&
             request.resource.data.entries.size() <= 50)) &&
          (!('status' in request.resource.data) ||
            request.resource.data.status in ['under', 'on', 'over']) &&
          (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is timestamp);
        allow delete: if isOwner(uid) && isNutritionDateKey(dateKey);
      }

      match /nutrition_year_summary/{year} {
        allow read: if isOwner(uid) && isYearKey(year);
        allow create, update: if isOwner(uid) &&
          isYearKey(year) &&
          request.resource.data.keys().hasOnly(['days']) &&
          request.resource.data.days is map;
        allow delete: if isOwner(uid) && isYearKey(year);
      }

      // Training plan stats per user (owner or active coach)
      match /training_plans/{planId}/meta/{docId} {
        allow read: if isOwner(uid) ||
          (isAuthed() && hasActiveCoaching(
            get(/databases/$(database)/documents/users/$(uid)/training_plans/$(planId)).data.gymId,
            uid
          )) ||
          (isAuthed() &&
            activeGymId() is string &&
            isAdmin(activeGymId()) &&
            isMember(uid, activeGymId()));
        allow write: if isOwner(uid);
      }

      // Training plans per user (owner or active coach)
      match /training_plans/{planId} {
        allow read: if isOwner(uid) ||
          (isAuthed() &&
            resource.data.gymId is string &&
            hasActiveCoaching(resource.data.gymId, uid)) ||
          (isAuthed() &&
            activeGymId() is string &&
            isAdmin(activeGymId()) &&
            isMember(uid, activeGymId()));
        allow create, update, delete: if isOwner(uid) ||
          (isAuthed() &&
            request.resource.data.gymId is string &&
            hasActiveCoaching(request.resource.data.gymId, uid));
      }

      // Fallback for other user subcollections (owner-only)
      match /trainingDayXP/{dayId} {
        // Owner, Global-Admin oder Admin des activeGymId, sofern Ziel-User dort Mitglied ist
        allow read, get, list: if
            isOwner(uid)
            || isGlobalAdmin()
            || (isAuthed()
                && activeGymId() is string
                && isAdmin(activeGymId())
                && isMember(uid, activeGymId()));
        allow write: if isOwner(uid);
      }

      // Training schedule per user (Plan-Zuweisung pro Tag)
      match /training_schedule/{dateKey} {
        allow read, get, list: if
            isOwner(uid)
            || isGlobalAdmin()
            || (isAuthed()
                && activeGymId() is string
                && isAdmin(activeGymId())
                && isMember(uid, activeGymId()))
            || (isAuthed()
                && activeGymId() is string
                && hasActiveCoaching(activeGymId(), uid));

        allow create, update: if
            isOwner(uid)
            || (isAuthed()
                && activeGymId() is string
                && hasActiveCoaching(activeGymId(), uid));

        allow delete: if isOwner(uid)
          || (isAuthed()
              && activeGymId() is string
              && isAdmin(activeGymId())
              && isMember(uid, activeGymId()));

        // Eingeschränkte Felder und Typen
        allow write: if request.resource.data.keys().hasOnly([
              'dateKey',
              'planId',
              'createdAt',
              'updatedAt'
            ])
            && request.resource.data.dateKey is string
            && request.resource.data.planId is string;
      }

      // NFC Scan Statistiken (profilweit, gym-agnostisch)
      match /nfc_scan_stats/{docId} {
        allow read, get, list: if isOwner(uid);
        allow create, update, delete: if isOwner(uid) &&
          request.resource.data.keys().hasOnly([
            'totalScans',
            'lastScanAt',
            'lastGymId',
            'lastDeviceId',
            'lastExerciseId',
            'updatedAt'
          ]);
      }

      match /{collection}/{document=**} {
        allow read, write: if isOwner(uid) &&
          ![
            'friends',
            'avatarsOwned',
            'avatarInventory',
            'publicCalendar',
            'friendMeta',
            'friendChats',
            'pushTokens',
            'settings',
            'creatine_intakes',
            'nutrition_goal_templates',
            'nutrition_goals',
            'nutrition_logs',
            'nutrition_year_summary',
            'training_plans',
            'trainingDayXP',
            'training_schedule',
            'nfc_scan_stats',
            'nutrition_recipes'
          ].hasAny([collection]);
      }
    }

    match /users/{uid}/nutrition_recipes/{recipeId} {
      allow read, write: if isOwner(uid);
    }


    match /nutrition_products/{barcode} {
      allow read: if isAuthed();
      allow create, update: if isAuthed() &&
        isBarcodeKey(barcode) &&
        request.resource.data.keys().hasOnly([
          'name',
          'kcalPer100',
          'proteinPer100',
          'carbsPer100',
          'fatPer100',
          'updatedAt'
        ]) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.name.size() <= 160 &&
        request.resource.data.kcalPer100 is int &&
        request.resource.data.kcalPer100 >= 0 &&
        request.resource.data.kcalPer100 <= 5000 &&
        request.resource.data.proteinPer100 is int &&
        request.resource.data.proteinPer100 >= 0 &&
        request.resource.data.proteinPer100 <= 500 &&
        request.resource.data.carbsPer100 is int &&
        request.resource.data.carbsPer100 >= 0 &&
        request.resource.data.carbsPer100 <= 500 &&
        request.resource.data.fatPer100 is int &&
        request.resource.data.fatPer100 >= 0 &&
        request.resource.data.fatPer100 <= 500 &&
        (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is timestamp);
      allow delete: if false;
    }

    // ─────────────────────────
    // Coaching relations (top-level)
    // ─────────────────────────
    match /coachClientRelations/{relationId} {
      // Coach oder Client dürfen ihre Relationen lesen.
      // Hinweis: Admin-Fallback wird hier bewusst NICHT genutzt,
      // um Query-Einschränkungen sauber abzubilden.
      allow read: if isAuthed() &&
        (request.auth.uid == resource.data.clientId ||
         request.auth.uid == resource.data.coachId);

      allow create: if isAuthed() &&
        request.resource.data.keys().hasOnly([
          'gymId',
          'coachId',
          'clientId',
          'status',
          'createdAt',
          'updatedAt',
          'endedAt',
          'endedReason',
          'note'
        ]) &&
        request.resource.data.gymId is string &&
        request.resource.data.coachId is string &&
        request.resource.data.clientId is string &&
        request.resource.data.status == 'pending' &&
        relationId == request.resource.data.gymId + '_' +
          request.resource.data.coachId + '_' +
          request.resource.data.clientId &&
        (request.auth.uid == request.resource.data.clientId ||
         isAdmin(request.resource.data.gymId));

      allow update: if isAuthed() &&
        request.resource.data.keys().hasOnly([
          'gymId',
          'coachId',
          'clientId',
          'status',
          'createdAt',
          'updatedAt',
          'endedAt',
          'endedReason',
          'note'
        ]) &&
        // Identitätsfelder dürfen nicht verändert werden.
        request.resource.data.gymId == resource.data.gymId &&
        request.resource.data.coachId == resource.data.coachId &&
        request.resource.data.clientId == resource.data.clientId &&
        request.resource.data.createdAt == resource.data.createdAt &&
        // Gültige Statuswerte
        request.resource.data.status in ['pending', 'active', 'ended', 'rejected'] &&
        (
          // Client can update own relation (z.B. abbrechen)
          request.auth.uid == resource.data.clientId ||
          // Admin des Gyms
          (resource.data.gymId is string && isAdmin(resource.data.gymId)) ||
          // Coach mit passender Membership und zugeordneter coachId
          (resource.data.gymId is string &&
           request.auth.uid == resource.data.coachId &&
           isCoach(resource.data.gymId))
        );

      allow delete: if isAuthed() &&
        (request.auth.uid == resource.data.clientId ||
         (resource.data.gymId is string && isAdmin(resource.data.gymId)));
    }

    // ─────────────────────────
    // Coach invites (top-level)
    // ─────────────────────────
    match /coachInvites/{inviteId} {
      allow read: if isAuthed() &&
        (request.auth.uid == resource.data.clientId ||
         (request.auth.token.email == resource.data.email) ||
         (resource.data.gymId is string && isAdmin(resource.data.gymId)));

      allow create: if isAuthed() &&
        request.resource.data.keys().hasOnly([
          'gymId',
          'clientId',
          'email',
          'status',
          'createdAt',
          'acceptedAt',
          'coachId'
        ]) &&
        request.resource.data.gymId is string &&
        request.resource.data.clientId == request.auth.uid &&
        request.resource.data.email is string &&
        request.resource.data.status == 'pending';

      allow update: if isAuthed() &&
        request.resource.data.keys().hasOnly([
          'gymId',
          'clientId',
          'email',
          'status',
          'createdAt',
          'acceptedAt',
          'coachId'
        ]) &&
        request.resource.data.gymId == resource.data.gymId &&
        request.resource.data.clientId == resource.data.clientId &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.status in ['pending', 'accepted', 'canceled', 'rejected'] &&
        (
          request.auth.uid == resource.data.clientId ||
          (resource.data.gymId is string && isAdmin(resource.data.gymId)) ||
          (request.auth.token.email == resource.data.email)
        );

      allow delete: if isAuthed() &&
        (request.auth.uid == resource.data.clientId ||
         (resource.data.gymId is string && isAdmin(resource.data.gymId)));
    }

    // ─────────────────────────
    // Coaching events / Audit-Log (top-level)
    // ─────────────────────────
    match /coachingEvents/{eventId} {
      allow read: if isAuthed() &&
        (
          (resource.data.clientId == request.auth.uid) ||
          (resource.data.coachId == request.auth.uid) ||
          (resource.data.gymId is string && isAdmin(resource.data.gymId))
        );

      allow create: if isAuthed() &&
        request.resource.data.keys().hasOnly([
          'gymId',
          'type',
          'actorId',
          'coachId',
          'clientId',
          'relationId',
          'planId',
          'inviteId',
          'createdAt'
        ]) &&
        request.resource.data.gymId is string &&
        request.resource.data.type is string &&
        request.resource.data.actorId == request.auth.uid &&
        request.resource.data.createdAt is string;

      // Audit-Einträge sind unveränderlich.
      allow update, delete: if false;
    }

    // ─────────────────────────
    // Gyms
    // ─────────────────────────
    match /gyms/{gymId} {
      // Public gym doc (non-sensitive fields only)
      allow read: if true;
      allow create, delete: if isAdmin(gymId);
      allow update: if isAdmin(gymId) || canIncrementMemberNumberCounter();

      // Branding / config
      match /config/{docId} {
        allow read: if isAuthed();
        allow write: if isAdmin(gymId);
      }

      // Avatar catalog per gym
      match /avatarCatalog/{avatarId} {
        allow read: if inGym(gymId) || isAdmin(gymId);
        allow write: if isAdmin(gymId);
      }

      // Devices
      match /devices/{deviceId} {
        allow read: if isAuthed();
        allow write: if isAdmin(gymId);

        // Device logs (immutable; owner append-only)
        match /logs/{logId} {
          allow create: if requestOwnerInGym(gymId);
          allow read: if resourceOwnerOrAdmin(gymId);
          allow delete: if resourceOwnerOrAdmin(gymId);
          allow update: if false;
        }

        // Session snapshots per user (read owner/admin; write owner-only)
        match /sessions/{sessionId} {
          allow create: if requestOwnerInGym(gymId);
          allow read: if resourceOwnerOrAdmin(gymId) ||
                       isFriend(resource.data.userId, request.auth.uid);
          allow delete: if resourceOwnerOrAdmin(gymId);
          allow update: if false;
        }

        // Per-user notes for device
        match /userNotes/{userId} {
          allow read, write: if ownerOrAdmin(gymId, userId);
        }

        // Leaderboard entries (owner/admin; allow markers)
        match /leaderboard/{userId} {
          allow read: if ownerOrAdmin(gymId, userId) ||
                       (inGym(gymId) && resource.data.showInLeaderboard == true);
          allow create, update: if ownerOrAdmin(gymId, userId) &&
                                request.resource.data.userId == userId;
          allow delete: if ownerOrAdmin(gymId, userId);

          // Daily markers
          match /days/{dayKey} {
            allow read: if ownerOrAdmin(gymId, userId);
            allow create: if ownerOrAdmin(gymId, userId);
            allow delete: if ownerOrAdmin(gymId, userId);
          }

          // Session markers
          match /sessions/{sessionId} {
            allow read: if ownerOrAdmin(gymId, userId);
            allow create: if ownerOrAdmin(gymId, userId);
            allow delete: if ownerOrAdmin(gymId, userId);
          }

          // Exercise markers for multi-exercise tracking
          match /exercises/{exerciseId} {
            allow read: if ownerOrAdmin(gymId, userId);
            allow create: if ownerOrAdmin(gymId, userId);
            allow delete: if ownerOrAdmin(gymId, userId);
          }
        }

        // Custom exercises (public, owner or friends; admin override)
        match /exercises/{exerciseId} {
          allow read: if isAdmin(gymId) ||
            isOwnerOrFriend('userId') ||
            isOwnerOrFriend('ownerId') ||
            isOwnerOrFriend('createdBy') ||
            isPublicExercise();
          allow write: if inGym(gymId) && (
                          request.auth.uid == request.resource.data.userId ||
                          request.auth.uid == resource.data.userId
                        ) || isAdmin(gymId);
        }
      }

      // Surveys
      match /surveys/{surveyId} {
        allow read: if inGym(gymId) || isAdmin(gymId);
        allow create, update, delete: if isAdmin(gymId);

        match /answers/{answerId} {
          allow create: if inGym(gymId) && request.auth.uid == request.resource.data.userId;
          allow read: if isAdmin(gymId);
          allow update, delete: if false;
        }
      }

      // Feedback
      match /feedback/{entryId} {
        allow create: if inGym(gymId) && request.resource.data.userId == request.auth.uid;
        allow read, update, delete: if isAdmin(gymId);
      }

      // Machine attempts (king/queen leaderboard)
      match /machines/{machineId} {
        allow read: if inGym(gymId);
        allow write: if false;

        match /attempts/{attemptId} {
          allow read: if inGym(gymId);
          allow create: if inGym(gymId) &&
            request.auth.uid == request.resource.data.userId &&
            request.resource.data.keys().hasOnly([
              'gymId',
              'machineId',
              'userId',
              'username',
              'e1rm',
              'reps',
              'weight',
              'createdAt',
              'isMulti',
              'gender',
              'bodyWeightKg'
            ]) &&
            request.resource.data.gymId == gymId &&
            request.resource.data.machineId == machineId &&
            request.resource.data.isMulti == false &&
            request.resource.data.username is string &&
            request.resource.data.username.size() > 0 &&
            request.resource.data.e1rm is number &&
            request.resource.data.e1rm > 0 &&
            (!('reps' in request.resource.data) ||
              (request.resource.data.reps is int && request.resource.data.reps > 0)) &&
            (!('weight' in request.resource.data) ||
              (request.resource.data.weight is number && request.resource.data.weight > 0)) &&
            (!('bodyWeightKg' in request.resource.data) ||
              (request.resource.data.bodyWeightKg is number && request.resource.data.bodyWeightKg > 0)) &&
            (!('gender' in request.resource.data) ||
              ['m', 'w', 'divers'].hasAny([request.resource.data.gender])) &&
            request.resource.data.createdAt == request.time &&
            isSingleDevice(gymId, machineId);
          allow update: if false;
          allow delete: if isAdmin(gymId);
        }
      }

      // Training plans
      match /trainingPlans/{planId}/{subdoc=**} {
        allow read, write: if inGym(gymId) && (
          isAdmin(gymId) ||
          request.auth.uid == request.resource.data.createdBy ||
          request.auth.uid == resource.data.createdBy
        );
      }

      // Muscle groups
      match /muscleGroups/{groupId} {
        allow read: if inGym(gymId) || isAdmin(gymId);
        allow write: if isAdmin(gymId);
      }

      // Manufacturers (gym-specific selection)
      match /manufacturers/{mId} {
        allow read: if inGym(gymId) || isAdmin(gymId);
        allow write: if isAdmin(gymId);
      }

      // Challenges
      match /challenges/{type}/{docId}/{sub=**} {
        allow read: if inGym(gymId);
        allow write: if isAdmin(gymId);
      }

      // Report daily aggregates (read model built by Cloud Functions)
      match /reportDaily/{dayKey} {
        allow read: if inGym(gymId) || isAdmin(gymId);
        allow write: if false;

        match /{sub=**} {
          allow read, write: if false;
        }
      }

      // Users subcollection under gym
      match /users/{userId} {
        allow read: if inGym(gymId) || (isAuthed() && request.auth.uid == userId);
        allow create: if isAuthed() &&
                       request.auth.uid == userId &&
                       request.resource.data.role == 'member';
        allow update: if isAdmin(gymId);
        allow delete: if isAdmin(gymId) ||
          (isAuthed() && request.auth.uid == userId);
      }

      // NFC tokens for gym registration
      match /nfc_tokens/{tokenId} {
        allow read: if isAuthed();
        allow create, update: if isAdmin(gymId);
        allow delete: if false;
      }

      match /users/{userId}/rank/{document=**} {
        allow read: if ownerOrAdmin(gymId, userId) ||
                     isFriend(userId, request.auth.uid) ||
                     (inGym(gymId) &&
                      get(/databases/$(database)/documents/users/$(userId)).data.showInLeaderboard == true &&
                      !isAdminLikeRole(get(/databases/$(database)/documents/users/$(userId)).data.role));
        allow write: if ownerOrAdmin(gymId, userId);
      }

      match /users/{userId}/{doc=**} {
        allow read, write: if ownerOrAdmin(gymId, userId);
      }

      match /stats_daily/{day} {
        allow read: if inGym(gymId);
        allow create, update: if inGym(gymId) &&
          request.resource.data.keys().hasOnly([
            'date',
            'dayKey',
            'repsTotal',
            'volumeTotal',
            'trainingSessions',
            'exerciseTotal',
            'setTotal'
          ]) &&
          request.resource.data.date is timestamp;
        allow delete: if false;
      }

      match /stats_applied/{sessionId} {
        allow create: if inGym(gymId) &&
          request.resource.data.keys().hasOnly(['userId', 'createdAt']) &&
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.createdAt == request.time;
        allow read, update, delete: if false;
      }

      match /feed_events/{eventId} {
        allow read: if inGym(gymId);
        allow create: if inGym(gymId) &&
          isFeedEventId(eventId, request.resource.data.dayKey, request.auth.uid) &&
          isFeedEventAllowedKeys(request.resource.data) &&
          ['day_summary', 'milestone'].hasAny([request.resource.data.type]) &&
          request.resource.data.createdAt == request.time &&
          request.resource.data.dayKey is string;
        allow update: if inGym(gymId) &&
          isFeedEventId(eventId, resource.data.dayKey, request.auth.uid) &&
          isFeedEventAllowedKeys(request.resource.data) &&
          ['day_summary', 'milestone'].hasAny([request.resource.data.type]) &&
          request.resource.data.dayKey == resource.data.dayKey &&
          request.resource.data.type == resource.data.type &&
          request.resource.data.createdAt == request.time;
        allow delete: if false;
      }

      // Fallback inside gyms (reportDaily is read-only by dedicated rule above)
      match /{collection}/{document=**} {
        allow read: if inGym(gymId);
        allow write: if isAdmin(gymId) && collection != 'reportDaily';
      }
    }

    // ─────────────────────────
    // Gym Codes (Rotating Registration Codes)
    // ─────────────────────────
    match /gym_codes/{gymId}/codes/{codeId} {
      // Allow anyone to read codes for validation during registration
      // This is safe because:
      // 1. Codes are temporary (expire after 30 days)
      // 2. Codes are random and hard to guess
      // 3. Only active, non-expired codes work for registration
      allow read: if true;
      
      // Only gym admins can create codes
      allow create: if isAdmin(gymId) &&
        request.resource.data.keys().hasOnly([
          'code',
          'gymId',
          'createdAt',
          'expiresAt',
          'isActive',
          'createdBy'
        ]) &&
        request.resource.data.code is string &&
        request.resource.data.code.size() == 6 &&
        request.resource.data.gymId == gymId &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.expiresAt is timestamp &&
        request.resource.data.isActive is bool &&
        request.resource.data.createdBy is string;
      
      // Only allow updating isActive field (for deactivation)
      allow update: if isAdmin(gymId) &&
        request.resource.data.keys().hasOnly([
          'code',
          'gymId',
          'createdAt',
          'expiresAt',
          'isActive',
          'createdBy'
        ]) &&
        request.resource.data.code == resource.data.code &&
        request.resource.data.gymId == resource.data.gymId &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.expiresAt == resource.data.expiresAt &&
        request.resource.data.createdBy == resource.data.createdBy;
      
      // Codes are immutable - no deletion
      allow delete: if false;
    }

    // Public deals (readable by any authenticated user)
    match /deals/{dealId} {
      allow read: if isAuthed();
      allow write: if isAuthed() && (
        isGlobalAdmin() || 
        isAdminLikeRole(request.auth.token.role) ||
        isAdminLikeRole(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role) ||
        isAdmin(activeGymId())
      );
    }

    // ─────────────────────────
    // Deny everything else
    // ─────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
